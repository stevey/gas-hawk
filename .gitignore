## Git Ignore
## Version Apr 1, 2026

# ignore all files starting with . or ~ (needs to be before .gitlab)
.*
~*

# ignore .idea directory
.idea/

# ignore node dependency directories
# ignore node dependency directories
# node_modules/
# vendor/

# ignore OS generated files
ehthumbs.db
Thumbs.db
.DS_Store

# ignore Editor files
*.sublime-project
*.sublime-workspace
*.komodoproject
*.idea

# ignore log files and databases
*.log
*.sql
*.sqlite

# ignore compiled files
*.com
*.class
*.dll
*.exe
*.o
*.so

# ignore packaged files
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

#allowed files
!.gitignore
!.gitkeep
